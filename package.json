{
  "name": "@rulvar/monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "rulvar monorepo root. Never published.",
  "type": "module",
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "pack-check": "turbo pack-check",
    "docs:lint": "node scripts/docs-lint.mjs",
    "docs:dev": "pnpm --filter @rulvar/docs dev",
    "docs:build": "pnpm --filter @rulvar/docs build:site",
    "check:fixed-group": "node scripts/check-fixed-group.mjs",
    "dts:baseline": "node scripts/dts-baseline.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version && node scripts/sync-pointer.mjs && pnpm --filter @rulvar/docs run build:sync",
    "release": "pnpm publish -r --publish-branch main"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@changesets/cli": "catalog:",
    "@eslint/js": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "publint": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/o-stepper/rulvar.git"
  },
  "homepage": "https://rulvar.com",
  "bugs": {
    "url": "https://github.com/o-stepper/rulvar/issues"
  }
}
