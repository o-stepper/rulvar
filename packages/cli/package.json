{
  "name": "@rulvar/cli",
  "version": "1.58.0",
  "description": "Rulvar shell: run/resume/runs/inspect/plan/kb commands, TUI progress, createServer, createWorker, OTel exporter.",
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "pack-check": "publint --pack pnpm && attw --pack . --profile esm-only"
  },
  "dependencies": {
    "@rulvar/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "@rulvar/testing": "workspace:*",
    "@rulvar/store-sqlite": "workspace:*",
    "@rulvar/planner": "workspace:*",
    "@rulvar/plan": "workspace:*",
    "@rulvar/evals": "workspace:*"
  },
  "bin": {
    "rulvar": "./dist/cli.js"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.9"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/o-stepper/rulvar.git",
    "directory": "packages/cli"
  },
  "homepage": "https://rulvar.com",
  "bugs": {
    "url": "https://github.com/o-stepper/rulvar/issues"
  }
}
