{
  "name": "@rulvar/rulvar",
  "version": "1.24.1",
  "description": "Rulvar umbrella package: re-exports @rulvar/core, both first-class adapters, the file store, and the terminal progress renderer. Also installable through the unscoped alias package rulvar, which re-exports this one.",
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "pack-check": "publint --pack pnpm && attw --pack . --profile esm-only"
  },
  "dependencies": {
    "@rulvar/core": "workspace:*",
    "@rulvar/anthropic": "workspace:*",
    "@rulvar/openai": "workspace:*"
  },
  "devDependencies": {
    "@rulvar/testing": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "zod": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/o-stepper/rulvar.git",
    "directory": "packages/rulvar"
  },
  "homepage": "https://rulvar.com",
  "bugs": {
    "url": "https://github.com/o-stepper/rulvar/issues"
  }
}
