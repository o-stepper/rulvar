{
  "name": "@rulvar/compat",
  "version": "0.1.0",
  "description": "rulvar frozen KeyDeriver profiles for hashVersions outside the support window (DEF-6); independently versioned.",
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "pack-check": "publint --pack pnpm && attw --pack . --profile esm-only"
  },
  "dependencies": {
    "@rulvar/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/o-stepper/rulvar.git",
    "directory": "packages/compat"
  },
  "homepage": "https://rulvar.com",
  "bugs": {
    "url": "https://github.com/o-stepper/rulvar/issues"
  }
}
