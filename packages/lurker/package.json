{
  "name": "@lurker/lurker",
  "version": "0.0.0",
  "description": "lurker umbrella package: re-exports @lurker/core, both first-class adapters, the file store, and the terminal progress renderer. Published as @lurker/lurker while the unscoped name is contingent (docs/13, section \"Naming risk note\").",
  "type": "module",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "pack-check": "publint --pack pnpm && attw --pack . --profile esm-only"
  },
  "dependencies": {
    "@lurker/core": "workspace:*",
    "@lurker/anthropic": "workspace:*",
    "@lurker/openai": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
