{
  "name": "eslint-plugin-rulvar",
  "version": "1.56.0",
  "description": "Rulvar determinism lint rules with structural JSON diagnostics for the planner self-repair loop.",
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "pack-check": "publint --pack pnpm && attw --pack . --profile esm-only"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "eslint": "catalog:",
    "@types/estree": "catalog:"
  },
  "peerDependencies": {
    "eslint": ">=9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/o-stepper/rulvar.git",
    "directory": "packages/eslint-plugin-rulvar"
  },
  "homepage": "https://rulvar.com",
  "bugs": {
    "url": "https://github.com/o-stepper/rulvar/issues"
  }
}
