{
  "$schema": "https://typedoc.org/schema.json",
  "name": "Rulvar API reference",
  "readme": "none",
  "entryPointStrategy": "packages",
  "entryPoints": [
    "../packages/core",
    "../packages/rulvar",
    "../packages/anthropic",
    "../packages/openai",
    "../packages/bridge-ai-sdk",
    "../packages/plan",
    "../packages/planner",
    "../packages/store-sqlite",
    "../packages/store-postgres",
    "../packages/store-conformance",
    "../packages/executor",
    "../packages/compat",
    "../packages/testing",
    "../packages/evals",
    "../packages/cli",
    "../packages/eslint-plugin-rulvar"
  ],
  "plugin": ["typedoc-plugin-markdown", "typedoc-vitepress-theme"],
  "out": "api",
  "indexFormat": "table",
  "parametersFormat": "table",
  "interfacePropertiesFormat": "table",
  "classPropertiesFormat": "table",
  "typeDeclarationFormat": "table",
  "expandObjects": true,
  "useCodeBlocks": true,
  "fileExtension": ".md",
  "hidePageHeader": false,
  "hideBreadcrumbs": false,
  "hidePageTitle": false,
  "publicPath": "/api/",
  "docsRoot": ".",
  "categorizeByGroup": true,
  "includeVersion": true,
  "excludePrivate": true,
  "excludeInternal": true,
  "excludeProtected": false,
  "excludeExternals": true,
  "excludeNotDocumented": false,
  "githubPages": false,
  "includeVersion": false,
  "skipErrorChecking": true,
  "logLevel": "Warn",
  "treatWarningsAsErrors": false,
  "blockTags": [
    "@alpha",
    "@beta",
    "@deprecated",
    "@example",
    "@experimental",
    "@inheritDoc",
    "@param",
    "@public",
    "@privateRemarks",
    "@readonly",
    "@remarks",
    "@returns",
    "@see",
    "@sealed",
    "@stable",
    "@throws",
    "@typeParam"
  ],
  "modifierTags": ["@hidden", "@internal", "@override", "@stable", "@experimental"],
  "validation": {
    "notExported": false,
    "invalidLink": true,
    "notDocumented": false
  },
  "sidebar": {
    "autoConfiguration": true,
    "format": "vitepress",
    "pretty": true,
    "collapsed": true
  },
  "disableGit": true,
  "basePath": "..",
  "packageOptions": {
    "entryPoints": ["src/index.ts"],
    "disableGit": true,
    "basePath": "../..",
    "sourceLinkTemplate": "https://github.com/o-stepper/rulvar/blob/main/{path}#L{line}"
  },
  "sourceLinkTemplate": "https://github.com/o-stepper/rulvar/blob/main/{path}#L{line}"
}
